# Muncher Macros v2 — Environment Variables
# Copy this file to .env and fill in your actual values.


# Google Analytics Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Anthropic Claude API Key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Supabase — Client-side (safe to expose, scoped by RLS)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Supabase — Server-side (used by API routes, never expose to client)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Stripe (payments)
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key-here
STRIPE_SECRET_KEY=your-stripe-secret-key-here
STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# CORS — Comma-separated list of allowed origins (defaults to production + localhost if empty)
ALLOWED_ORIGINS=http://localhost:5173,https://munchermacros.com
