{
  "functions": {
    "api/ai-label.js": { "maxDuration": 30 },
    "api/ai-barcode.js": { "maxDuration": 30 },
    "api/ai-describe.js": { "maxDuration": 30 },
    "api/ai-lookup.js": { "maxDuration": 30 },
    "api/ai-verify-meal.js": { "maxDuration": 30 },
    "api/ai-ingredients.js": { "maxDuration": 15 }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}

