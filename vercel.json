{
  "functions": {
    "api/ai.js":      { "maxDuration": 30, "memory": 1024 },
    "api/search.js":  { "maxDuration": 20, "memory": 512 },
    "api/tracker.js": { "maxDuration": 20, "memory": 256 },
    "api/stripe.js":  { "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}

